# Eledia Solr 9.9.0 - Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================================
# CUSTOMER IDENTIFICATION
# ============================================================
CUSTOMER_NAME=default

# ============================================================
# SOLR CORE CONFIGURATION
# ============================================================
SOLR_CORE_NAME=moodle

# ============================================================
# AUTHENTICATION
# ============================================================
# Enable/disable authentication (true/false)
SOLR_AUTH_ENABLED=true

# Admin user credentials (full access)
SOLR_ADMIN_USER=admin
# Leave empty to auto-generate:
SOLR_ADMIN_PASSWORD=

# Support user credentials (read-only + limited admin)
SOLR_SUPPORT_USER=support
# Leave empty to auto-generate:
SOLR_SUPPORT_PASSWORD=

# Customer user credentials (read-only)
SOLR_CUSTOMER_USER=customer
# Leave empty to auto-generate:
SOLR_CUSTOMER_PASSWORD=

# ============================================================
# MOODLE SCHEMA SUPPORT
# ============================================================
# Enable Moodle-specific schema (true/false)
# DEFAULT: true (Moodle 4.1-5.0.x optimized out of the box)
SOLR_USE_MOODLE_SCHEMA=true

# ============================================================
# NETWORK CONFIGURATION
# ============================================================
# Solr port binding (use 127.0.0.1:8983 for local-only access)
SOLR_PORT=127.0.0.1:8983

# ============================================================
# PERFORMANCE TUNING
# ============================================================
# JVM Heap size (recommended: 50% of container memory)
# Production default: 2g (suitable for most Moodle installations)
SOLR_HEAP=2g

# JVM Memory settings (should match heap size)
SOLR_JAVA_MEM=-Xms2g -Xmx2g

# Total container memory limit (generous for Moodle production use)
# 4g allows comfortable indexing and searching for large Moodle sites
SOLR_MEMORY_LIMIT=4g

# Solr log level (TRACE, DEBUG, INFO, WARN, ERROR)
SOLR_LOG_LEVEL=INFO

# ============================================================
# DEBUG MODE
# ============================================================
# Enable debug mode for detailed error messages and troubleshooting
# Set to 'true' to enable verbose output and command tracing
# Default: false
DEBUG=false

# ============================================================
# NOTES
# ============================================================
# - If passwords are not set, they will be auto-generated
# - Generated credentials are saved to /var/solr/credentials.txt
# - For production, always set custom passwords!
# - Restart container after changing .env file: docker-compose up -d --force-recreate
