CUSTOMER_NAME=test
SOLR_CORE_NAME=moodle
SOLR_AUTH_ENABLED=true
SOLR_USE_MOODLE_SCHEMA=true
SOLR_HEAP=512m
SOLR_JAVA_MEM=-Xms512m -Xmx512m
SOLR_MEMORY_LIMIT=1g
DEBUG=false
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=/var/solr/backups
LOG_ROTATION_ENABLED=true
LOG_MAX_SIZE=100M
LOG_MAX_FILES=10
LOG_COMPRESSION=true
